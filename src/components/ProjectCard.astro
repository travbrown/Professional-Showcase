---
import type { Project } from "../lib/github";

interface Props {
  project: Project;
  index: number;
}

const { project, index } = Astro.props;
---

<div
  class="project-card-link"
  style={`transition-delay: ${index * 0.1}s`}
>
  <article class="project-card animate-on-scroll">
    {project.image && (
      <div class="project-image">
        <img src={project.image} alt={project.title} loading="lazy" />
      </div>
    )}
    <div class="project-content">
      <div class="project-header">
        <h3><a href={`/projects/${project.slug}`} class="card-link">{project.title}</a></h3>
        <div class="project-badges">
          {project.featured && <span class="badge">Featured</span>}
          {project.visibility === "private" && (
            <span class="badge badge-private">Private</span>
          )}
          {project.visibility === "nda" && (
            <span class="badge badge-nda">NDA</span>
          )}
          {project.company && (
            <span
              class={`badge badge-company badge-${project.company.toLowerCase()}`}
            >
              @ {project.company}
            </span>
          )}
        </div>
      </div>
      <p class="project-desc">{project.description}</p>
      {project.tags.length > 0 && (
        <div class="project-tags">
          {project.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
      <div class="project-links">
        {project.repoUrl && (
          <a href={project.repoUrl} target="_blank" rel="noopener noreferrer">
            Source &rarr;
          </a>
        )}
        {project.liveUrl && (
          <a href={project.liveUrl} target="_blank" rel="noopener noreferrer">
            Live &rarr;
          </a>
        )}
      </div>
    </div>
  </article>
</div>

<style>
  .project-card-link {
    display: block;
    position: relative;
    color: inherit;
    cursor: pointer;
  }

  .card-link {
    color: inherit;
    border: none;
    text-decoration: none;
  }

  .card-link::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .project-card {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition:
      transform var(--transition),
      box-shadow var(--transition),
      border-color var(--transition);
    height: 100%;
  }

  .project-card-link:hover .project-card {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
    border-color: var(--accent);
  }

  .project-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }

  .project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%);
    transition: filter 0.4s ease;
  }

  .project-card-link:hover .project-image img {
    filter: grayscale(0%);
  }

  .project-content {
    padding: 24px;
  }

  .project-header {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-bottom: 8px;
    flex-wrap: wrap;
  }

  .project-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .badge {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 2px 8px;
    background: var(--text);
    color: var(--bg);
    border-radius: 3px;
    white-space: nowrap;
  }

  .badge-private {
    background: var(--text-muted);
    color: var(--bg);
  }

  .badge-nda {
    background: transparent;
    color: var(--text-muted);
    border: 1px solid var(--border);
  }

  .badge-company {
    background: transparent;
    font-style: italic;
  }

  .badge-google {
    color: #4285f4;
    border: 1px solid rgba(66, 133, 244, 0.3);
  }

  .badge-salesforce {
    color: #00a1e0;
    border: 1px solid rgba(0, 161, 224, 0.3);
  }

  .project-desc {
    font-size: 0.9rem;
    margin-bottom: 16px;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 16px;
  }

  .tag {
    font-size: 0.7rem;
    padding: 3px 10px;
    border: 1px solid var(--border);
    border-radius: 3px;
    color: var(--text-muted);
  }

  .project-links {
    display: flex;
    gap: 16px;
  }

  .project-links a {
    font-size: 0.8rem;
    color: var(--text-muted);
    border: none;
    transition: color var(--transition);
    position: relative;
    z-index: 1;
  }

  .project-links a:hover {
    color: var(--text);
  }
</style>
